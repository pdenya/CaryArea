---
import { ICONS } from '../lib/icons';

interface Props {
  name: string;
  class?: string;
}

const { name, class: cls } = Astro.props;
const inner = ICONS[name] ?? ICONS.sun;
---

<svg
  class={cls}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.8"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  set:html={inner}
/>
