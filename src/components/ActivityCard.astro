---
import type { CollectionEntry } from 'astro:content';
import { CATEGORIES, withBase } from '../lib/site';
import { iconFor } from '../lib/icons';
import Icon from './Icon.astro';

interface Props {
  activity: CollectionEntry<'activities'>;
  featured?: boolean;
}

const { activity, featured = false } = Astro.props;
const { title, blurb, category, area, cost, heat, date, warning, bookAhead } = activity.data;
const cat = CATEGORIES[category];
const icon = iconFor(activity.id, category);

/* ——— Date → trip days (Jul 5=Sat … Jul 11=Sat) ——— */
function parseTripDays(d?: string): number[] {
  if (!d) return [];
  const lc = d.toLowerCase();
  if (lc.includes('all week')) return [7, 8, 9, 10, 11];

  const days = new Set<number>();

  // "Jul N" or "7/N" patterns — authoritative
  for (const m of d.matchAll(/(?:Jul\s+|7\/)(\d{1,2})/gi)) {
    const n = parseInt(m[1], 10);
    if (n >= 5 && n <= 12) days.add(n);
  }

  // Day-of-week abbreviations as fallback (only when no explicit Jul dates found)
  if (days.size === 0) {
    const DOW_TO_DAY: Record<string, number> = { Tue: 7, Wed: 8, Thu: 9, Fri: 10, Sat: 11 };
    for (const m of d.matchAll(/\b(Tue|Wed|Thu|Fri|Sat)\b/gi)) {
      const key = m[1].charAt(0).toUpperCase() + m[1].slice(1).toLowerCase();
      if (DOW_TO_DAY[key]) days.add(DOW_TO_DAY[key]);
    }
  }

  // Range fill: "Jul 8 – Fri Jul 10" or "7/7–Sun 7/12" → fill between endpoints
  const rangeMatch = d.match(/(?:Jul\s+|7\/)(\d{1,2})\s*[–→\-]\s*(?:\w+\s+)?(?:Jul\s+|7\/)(\d{1,2})/i);
  if (rangeMatch) {
    const a = parseInt(rangeMatch[1], 10);
    const b = parseInt(rangeMatch[2], 10);
    for (let i = Math.min(a, b); i <= Math.max(a, b); i++) {
      if (i >= 5 && i <= 12) days.add(i);
    }
  }

  return [...days].sort((a, b) => a - b);
}

const tripDays = parseTripDays(date);
const daysAttr = tripDays.length > 0 ? tripDays.join(',') : 'any';

const HEAT_GLYPH: Record<string, { icon: string; label: string }> = {
  ac: { icon: 'snow', label: 'A/C' },
  water: { icon: 'droplet', label: 'Water' },
  shade: { icon: 'tree', label: 'Shade' },
  timing: { icon: 'sun', label: 'AM/PM' },
};
const hg = HEAT_GLYPH[heat] ?? HEAT_GLYPH.timing;
---

<a
  class:list={['activity-card', { featured }]}
  href={withBase(`/activities/${activity.id}/`)}
  style={`--cat:${cat.color};--grad:${cat.grad}`}
  data-area={area}
  data-days={daysAttr}
>
  <span class="medallion"><Icon name={icon} /></span>

  <div class="body">
    <h3>{title}</h3>
    {date && <span class="card-date">{date}</span>}
    <p class="blurb">{blurb}</p>
    <div class="foot">
      <span class="cost">{cost}</span>
      <span class="foot-dot">·</span>
      <span class="area">{area}</span>
      <span class="foot-spacer"></span>
      <span class="heat"><Icon name={hg.icon} />{hg.label}</span>
    </div>
    {(bookAhead || warning) && (
      <div class="flags">
        {bookAhead && <span class="flag flag-book">Book ahead</span>}
        {warning && <span class="flag flag-warn">Heads up</span>}
      </div>
    )}
  </div>
  <span class="go" aria-hidden="true">↗</span>
</a>

<style>
  .activity-card {
    --cat: var(--ink);
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.95rem;
    align-items: start;
    background: var(--card);
    border: 1.5px solid var(--line);
    border-left: 5px solid color-mix(in srgb, var(--cat) 70%, var(--line));
    border-radius: 15px;
    padding: 1.05rem 1.1rem;
    text-decoration: none;
    overflow: hidden;
    isolation: isolate;
    transition: border-color 0.18s ease, transform 0.12s ease, box-shadow 0.18s ease;
  }

  /* subtle corner bloom — just a whisper on regular cards */
  .activity-card::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background: var(--grad);
    opacity: 0.04;
    -webkit-mask: radial-gradient(120% 88% at 100% 0%, #000, transparent 60%);
    mask: radial-gradient(120% 88% at 100% 0%, #000, transparent 60%);
  }

  /* saturated icon medallion — the card's loud identity */
  .medallion {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.3rem;
    height: 3.3rem;
    flex: none;
    border-radius: 14px;
    color: #fff;
    background: var(--grad);
    box-shadow: 0 4px 12px -3px color-mix(in srgb, var(--cat) 65%, transparent);
  }
  .medallion :global(svg) { width: 1.75rem; height: 1.75rem; }

  .body { min-width: 0; }

  .activity-card h3 {
    font-size: 1.24rem;
    font-weight: 640;
    line-height: 1.1;
    color: var(--ink);
  }

  .card-date {
    display: inline-block;
    margin-top: 0.28rem;
    font-family: var(--font-body);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--cat);
  }

  .blurb {
    margin: 0.42rem 0 0.7rem;
    color: var(--ink-soft);
    font-size: 0.92rem;
    line-height: 1.42;
  }

  .foot {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
    min-width: 0;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.04em;
  }
  .cost {
    min-width: 0;
    color: var(--ink);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    overflow-wrap: anywhere;
  }
  .foot-dot { color: color-mix(in srgb, var(--cat) 50%, var(--line)); }
  .area {
    color: var(--ink-soft);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .foot-spacer { flex: 1; }

  .heat {
    display: inline-flex;
    align-items: center;
    gap: 0.3em;
    color: var(--cat);
    background: color-mix(in srgb, var(--cat) 16%, #fff);
    border: 1px solid color-mix(in srgb, var(--cat) 40%, var(--line));
    border-radius: 999px;
    padding: 0.2em 0.6em 0.2em 0.5em;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.64rem;
    white-space: nowrap;
  }
  .heat :global(svg) { width: 0.85rem; height: 0.85rem; }

  .flags { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 0.6rem; }
  .flag {
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-radius: 999px;
    padding: 0.24em 0.65em;
  }
  .flag-book { background: var(--grad); color: #fff; }
  .flag-warn {
    color: var(--terra);
    background: color-mix(in srgb, var(--terra) 12%, var(--card));
    border: 1px solid color-mix(in srgb, var(--terra) 40%, var(--card));
  }

  .go {
    position: absolute;
    top: 0.85rem;
    right: 0.95rem;
    font-family: var(--font-display);
    font-style: italic;
    color: color-mix(in srgb, var(--cat) 60%, var(--line));
    font-size: 1rem;
  }

  @media (hover: hover) {
    .activity-card:hover {
      border-color: var(--cat);
      transform: translateY(-2px);
      box-shadow: 0 10px 24px -14px color-mix(in srgb, var(--cat) 80%, transparent);
    }
  }
  .activity-card:active { transform: translateY(0); }

  /* ---------- featured (top pick) — filled, loud, spans the row ---------- */
  .activity-card.featured {
    grid-column: 1 / -1;
    background: var(--grad);
    border-color: transparent;
    border-left-color: transparent;
    color: #fff;
    padding: 1.2rem 1.3rem;
  }
  .activity-card.featured::before {
    background: rgba(255, 255, 255, 0.14);
    opacity: 1;
    -webkit-mask: radial-gradient(150% 120% at 100% 100%, #000, transparent 55%);
    mask: radial-gradient(150% 120% at 100% 100%, #000, transparent 55%);
  }
  .activity-card.featured .medallion {
    background: rgba(255, 255, 255, 0.22);
    box-shadow: none;
    width: 3.5rem;
    height: 3.5rem;
  }
  .activity-card.featured h3 { color: #fff; font-size: 1.5rem; }
  .activity-card.featured .blurb { color: rgba(255, 255, 255, 0.92); }
  .activity-card.featured .card-date { color: #fff; }
  .activity-card.featured .cost,
  .activity-card.featured .area { color: #fff; }
  .activity-card.featured .foot-dot { color: rgba(255, 255, 255, 0.55); }
  .activity-card.featured .heat {
    color: #fff;
    background: rgba(255, 255, 255, 0.18);
    border-color: rgba(255, 255, 255, 0.4);
  }
  .activity-card.featured .flag-book { background: #fff; color: var(--cat); }
  .activity-card.featured .flag-warn {
    color: #fff;
    background: rgba(255, 255, 255, 0.16);
    border-color: rgba(255, 255, 255, 0.4);
  }
  .activity-card.featured .go { color: rgba(255, 255, 255, 0.9); }

  /* on wide multi-column grids, keep the hero from stretching absurdly tall/wide:
     let it span two tracks max via its own inner layout staying left-aligned */
  @media (min-width: 560px) {
    .activity-card.featured { align-items: center; }
  }
</style>
