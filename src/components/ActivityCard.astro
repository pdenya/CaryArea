---
import type { CollectionEntry } from 'astro:content';
import { HEAT, tile, withBase } from '../lib/site';

interface Props {
  activity: CollectionEntry<'activities'>;
  index?: number;
}

const { activity, index = 0 } = Astro.props;
const { title, blurb, area, cost, heat, date, warning, bookAhead } = activity.data;
const heatInfo = HEAT[heat];
const accent = tile(index);
---

<a class="activity-card" href={withBase(`/activities/${activity.id}/`)} style={`--cat:${accent.color};--cat-grad:${accent.grad}`}>
  <div class="card-top">
    <h3>{title}</h3>
    <span class="heat-badge" style={`--c:${heatInfo.color}`}>{heatInfo.label}</span>
  </div>
  {date && <span class="meta-caps card-date">{date}</span>}
  <p class="blurb">{blurb}</p>
  <div class="card-meta">
    <span class="meta-caps">{area}</span>
    <span class="meta-caps" style="color:var(--ink);">{cost}</span>
    {bookAhead && <span class="flag flag-book">Book ahead</span>}
    {warning && <span class="flag flag-warn">Heads up</span>}
    <span class="go" aria-hidden="true">↗</span>
  </div>
</a>
