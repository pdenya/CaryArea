---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ActivityCard from '../components/ActivityCard.astro';
import { CATEGORIES, CATEGORY_ORDER, appeal, eventDay, withBase } from '../lib/site';

const all = await getCollection('activities');

/* ——— Location filter setup ——— */
const LOCATION_GROUPS = ['Cary', 'Apex', 'Morrisville', 'Raleigh', 'Durham', 'Chapel Hill'] as const;

// Collect all unique areas for the "Other" bucket
const allAreas = [...new Set(all.map((a) => a.data.area))];
const otherAreas = allAreas.filter(
  (area) => !LOCATION_GROUPS.some((loc) => area.includes(loc))
);
const hasOther = otherAreas.length > 0;

const byCategory = CATEGORY_ORDER.map((key) => {
  const items = all.filter((a) => a.data.category === key);
  items.sort(
    (a, b) =>
      appeal(b.id) - appeal(a.id) ||
      (key === 'events' ? eventDay(a.data.date) - eventDay(b.data.date) : 0) ||
      a.data.title.localeCompare(b.data.title)
  );
  return { key, ...CATEGORIES[key], items };
});

const alerts = [
  { slug: 'wet-n-wild-emerald-pointe', text: 'Wet’n Wild online discount (up to 45% off) ends Mon Jul 6', chip: 'Ends Jul 6' },
  { slug: 'carolina-beach-overnight', text: 'Beach overnight? Carolina Beach hotels for fireworks night — book today', chip: 'Book today' },
  { slug: 'duke-lemur-center', text: 'Duke Lemur Center sells out in July — reserve immediately if wanted', chip: 'Sells out' },
  { slug: 'fantasy-lake-adventure-park', text: 'Fantasy Lake sessions sell out in July — buy passes + waivers online', chip: 'Sells out' },
];
---

<Base>
  <section class="hero">
    <div class="wrap hero-inner">
      <div class="sun" aria-hidden="true"></div>
      <p class="meta-caps eyebrow">Field Guide № 1 · Cary — Raleigh — Durham · July 7–11, 2026</p>
      <h1>
        It’s 98° in the shade.<br />
        <em>We have a plan.</em>
      </h1>
      <p class="lede">
        {all.length} researched ways to have a great week around the
        Triangle — every one sorted by how it handles a heat wave.
      </p>
      <div class="strategy" role="list">
        <span role="listitem"><b>Mornings & evenings</b> — anything outdoors</span>
        <span role="listitem"><b>12–5pm</b> — air conditioning or water, no exceptions</span>
        <span role="listitem"><b>Always</b> — sunscreen, hats, water bottles</span>
      </div>
    </div>
  </section>

  <section class="wrap alerts">
    <h2 class="alerts-title">⏱ Decide fast</h2>
    <ul>
      {alerts.map((a) => (
        <li>
          <span class="flag flag-warn">{a.chip}</span>
          <a href={withBase(`/activities/${a.slug}/`)}>{a.text}</a>
        </li>
      ))}
    </ul>
  </section>

  <nav class="wrap toc" aria-label="Categories">
    {byCategory.map((c) => (
      <a href={withBase(`/#${c.key}`)} style={`--cat:${c.color};--cat-grad:${c.grad}`}>
        <span class="toc-num">{c.num}</span>
        <span class="toc-label">{c.label}</span>
        <span class="toc-count">{c.items.length}</span>
      </a>
    ))}
    <a href={withBase('/plan/')} class="toc-plan">
      <span class="toc-num">✳</span>
      <span class="toc-label">The Day-by-Day Plan</span>
      <span class="toc-count">→</span>
    </a>
  </nav>

  <div class="wrap filter-bar" id="filter-bar">
    <div class="filter-row">
      <span class="filter-label meta-caps">Area</span>
      <div class="filter-pills">
        <button class="filter-pill active" data-loc="all">All</button>
        {LOCATION_GROUPS.map((loc) => (
          <button class="filter-pill" data-loc={loc}>{loc}</button>
        ))}
        {hasOther && <button class="filter-pill" data-loc="other">Other</button>}
      </div>
    </div>
    <div class="filter-row">
      <span class="filter-label meta-caps">Date</span>
      <div class="filter-pills">
        <button class="filter-pill active" data-day="all">Any date</button>
        <button class="filter-pill" data-day="5">Sat 7/5</button>
        <button class="filter-pill" data-day="6">Sun 7/6</button>
        <button class="filter-pill" data-day="7">Tue 7/7</button>
        <button class="filter-pill" data-day="8">Wed 7/8</button>
        <button class="filter-pill" data-day="9">Thu 7/9</button>
        <button class="filter-pill" data-day="10">Fri 7/10</button>
        <button class="filter-pill" data-day="11">Sat 7/11</button>
      </div>
    </div>
    <span class="filter-count" id="filter-count"></span>
  </div>

  <main class="wrap">
    {byCategory.map((c) => (
      <section class="cat-section" id={c.key}>
        <header class="cat-header" style={`--cat:${c.color};--cat-grad:${c.grad}`}>
          <span class="cat-num">{c.num}</span>
          <h2>{c.label}</h2>
          <span class="cat-count">× {c.items.length}</span>
          <span class="cat-desc">{c.desc}</span>
        </header>
        <div class="card-grid">
          {c.items.map((activity, i) => <ActivityCard activity={activity} featured={i === 0} />)}
        </div>
      </section>
    ))}
  </main>
</Base>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--line);
    background: linear-gradient(180deg, color-mix(in srgb, var(--gold) 10%, var(--paper)), var(--paper));
  }

  .hero-inner {
    position: relative;
    padding-top: clamp(3.5rem, 8vw, 6rem);
    padding-bottom: clamp(2.5rem, 6vw, 4.5rem);
  }

  .sun {
    position: absolute;
    top: -140px;
    right: -120px;
    width: 560px;
    height: 560px;
    background:
      radial-gradient(circle, var(--gold) 0 26%, transparent 27%),
      repeating-conic-gradient(var(--gold) 0deg 4deg, transparent 4deg 13deg);
    -webkit-mask: radial-gradient(circle, #000 0 62%, transparent 72%);
    mask: radial-gradient(circle, #000 0 62%, transparent 72%);
    opacity: 0.3;
    animation: sunspin 140s linear infinite;
    pointer-events: none;
  }

  @keyframes sunspin { to { transform: rotate(360deg); } }

  .eyebrow { color: var(--terra); margin-bottom: 1.2rem; }

  h1 {
    font-size: clamp(2.6rem, 7.2vw, 5.4rem);
    font-weight: 640;
    max-width: 14em;
  }

  h1 em {
    font-style: italic;
    font-weight: 420;
    background: var(--grad-sunset);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .lede {
    font-size: clamp(1.05rem, 2vw, 1.3rem);
    color: var(--ink-soft);
    max-width: 34em;
    margin: 1.4rem 0 1.8rem;
  }

  .strategy {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .strategy span {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    font-size: 0.85rem;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.45em 1em;
  }

  .strategy span::before {
    content: '';
    width: 0.5em;
    height: 0.5em;
    border-radius: 50%;
    background: var(--grad-sunset);
    flex: none;
  }

  .strategy b { color: var(--terra); white-space: nowrap; }

  /* alerts */
  .alerts {
    margin-top: 2.6rem;
  }

  .alerts-title {
    font-size: 1.5rem;
    font-weight: 680;
    margin-bottom: 0.8rem;
    width: max-content;
    background: var(--grad-sunset);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .alerts ul {
    list-style: none;
    margin: 0;
    padding: 1.1rem 1.3rem;
    border: 2px solid transparent;
    border-radius: 14px;
    background:
      linear-gradient(color-mix(in srgb, var(--terra) 5%, var(--card)), color-mix(in srgb, var(--terra) 5%, var(--card))) padding-box,
      var(--grad-sunset) border-box;
    display: grid;
    gap: 0.65rem;
  }

  .alerts li {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
  }

  .alerts a {
    text-decoration-color: color-mix(in srgb, var(--terra) 50%, transparent);
    text-underline-offset: 3px;
  }

  .alerts a:hover { color: var(--terra); }

  /* toc */
  .toc {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.6rem;
    margin-top: 2.2rem;
  }

  @media (min-width: 520px) {
    .toc { grid-template-columns: repeat(auto-fill, minmax(228px, 1fr)); gap: 0.7rem; }
  }

  .toc a {
    position: relative;
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    text-decoration: none;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 0.85rem 1rem;
    overflow: hidden;
    transition: border-color 0.2s ease, background-color 0.2s ease;
  }

  /* gradient baseline that sweeps across on hover/tap — replaces the edge bar */
  .toc a::after {
    content: '';
    position: absolute;
    left: 1rem;
    bottom: 0;
    height: 3px;
    width: 1.7rem;
    border-radius: 3px 3px 0 0;
    background: var(--cat-grad);
    transition: width 0.28s ease;
  }

  .toc a:active { border-color: color-mix(in srgb, var(--cat) 50%, var(--line)); }
  .toc a:active::after { width: calc(100% - 2rem); }

  @media (hover: hover) {
    .toc a:hover {
      border-color: color-mix(in srgb, var(--cat) 45%, var(--line));
      background: color-mix(in srgb, var(--cat) 5%, var(--card));
    }
    .toc a:hover::after { width: calc(100% - 2rem); }
    .toc a:hover .toc-count { transform: translateX(3px); }
  }

  .toc-num {
    font-family: var(--font-display);
    font-style: italic;
    background: var(--cat-grad);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .toc-label {
    flex: 1;
    font-weight: 760;
    font-size: 0.92rem;
  }

  .toc-count {
    font-family: var(--font-display);
    font-style: italic;
    background: var(--cat-grad);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    transition: transform 0.2s ease;
  }

  /* a.toc-plan to outrank the base `.toc a` background */
  .toc a.toc-plan {
    /* darker end of the sunset so white text stays legible */
    background: linear-gradient(105deg, #ff6a2b, #e6186c);
    border-color: transparent;
    color: #fff;
  }

  .toc a.toc-plan .toc-num,
  .toc a.toc-plan .toc-count {
    background: none;
    -webkit-text-fill-color: #fff;
    color: #fff;
  }

  .toc a.toc-plan::after { background: rgba(255, 255, 255, 0.92); }

  /* ————— filter bar ————— */
  .filter-bar {
    position: sticky;
    top: 52px;
    z-index: 90;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-top: 1.6rem;
    padding-top: 0.6rem;
    padding-bottom: 0.6rem;
    background: color-mix(in srgb, var(--paper) 90%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--line-soft);
  }

  .filter-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.4rem 0.7rem;
  }

  .filter-label {
    color: var(--ink-soft);
    flex: none;
    min-width: 2.8rem;
  }

  .filter-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .filter-pill {
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: var(--card);
    border: 1.5px solid var(--line);
    border-radius: 999px;
    padding: 0.32em 0.85em;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
    color: var(--ink-soft);
  }

  .filter-pill:hover {
    border-color: var(--ink-soft);
    color: var(--ink);
  }

  .filter-pill.active {
    background: var(--grad-sunset);
    border-color: transparent;
    color: #fff;
  }

  .filter-count {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.88rem;
    color: var(--ink-soft);
  }

  /* hide filtered-out cards & empty sections */
  :global(.activity-card.location-hidden) { display: none !important; }
  :global(.cat-section.section-hidden) { display: none !important; }
</style>

<script define:vars={{ LOCATION_GROUPS, otherAreas }}>
  document.addEventListener('DOMContentLoaded', () => {
    const locPills = document.querySelectorAll('.filter-pill[data-loc]');
    const dayPills = document.querySelectorAll('.filter-pill[data-day]');
    const countEl = document.getElementById('filter-count');
    const sections = document.querySelectorAll('.cat-section');
    const activeLocs = new Set();
    let activeDay = null; // null = any date

    function applyFilter() {
      const cards = document.querySelectorAll('.activity-card[data-area]');
      let shown = 0;
      let total = cards.length;
      const locAll = activeLocs.size === 0;
      const dayAll = activeDay === null;
      const isFiltered = !locAll || !dayAll;

      cards.forEach((card) => {
        const area = card.getAttribute('data-area') || '';
        const days = card.getAttribute('data-days') || 'any';

        // location match
        let locMatch = locAll;
        if (!locAll) {
          for (const loc of activeLocs) {
            if (loc === 'other') {
              if (!LOCATION_GROUPS.some((g) => area.includes(g))) { locMatch = true; break; }
            } else {
              if (area.includes(loc)) { locMatch = true; break; }
            }
          }
        }

        // date match: "any" activities always match, dated activities match if the selected day is in their list
        let dayMatch = dayAll;
        if (!dayAll) {
          if (days === 'any') {
            dayMatch = true; // undated = available any day
          } else {
            dayMatch = days.split(',').includes(activeDay);
          }
        }

        const visible = locMatch && dayMatch;
        card.classList.toggle('location-hidden', !visible);
        if (visible) shown++;
      });

      sections.forEach((section) => {
        const visibleCards = section.querySelectorAll('.activity-card:not(.location-hidden)');
        section.classList.toggle('section-hidden', visibleCards.length === 0);
      });

      countEl.textContent = isFiltered ? `${shown} of ${total}` : '';

      locPills.forEach((p) => {
        const loc = p.getAttribute('data-loc');
        p.classList.toggle('active', loc === 'all' ? locAll : activeLocs.has(loc));
      });
      dayPills.forEach((p) => {
        const day = p.getAttribute('data-day');
        p.classList.toggle('active', day === 'all' ? dayAll : activeDay === day);
      });
    }

    locPills.forEach((pill) => {
      pill.addEventListener('click', () => {
        const loc = pill.getAttribute('data-loc');
        if (loc === 'all') {
          activeLocs.clear();
        } else {
          if (activeLocs.has(loc)) {
            activeLocs.delete(loc);
          } else {
            activeLocs.add(loc);
          }
        }
        applyFilter();
      });
    });

    dayPills.forEach((pill) => {
      pill.addEventListener('click', () => {
        const day = pill.getAttribute('data-day');
        if (day === 'all') {
          activeDay = null;
        } else {
          activeDay = activeDay === day ? null : day;
        }
        applyFilter();
      });
    });
  });
</script>
