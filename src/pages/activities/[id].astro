---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ActivityCard from '../../components/ActivityCard.astro';
import { CATEGORIES, HEAT, withBase } from '../../lib/site';

export async function getStaticPaths() {
  const activities = await getCollection('activities');
  return activities.map((activity) => ({
    params: { id: activity.id },
    props: { activity, all: activities },
  }));
}

interface Props {
  activity: CollectionEntry<'activities'>;
  all: CollectionEntry<'activities'>[];
}

const { activity, all } = Astro.props;
const { Content } = await render(activity);
const d = activity.data;
const cat = CATEGORIES[d.category];
const heatInfo = HEAT[d.heat];

const related = all
  .filter((a) => a.data.category === d.category && a.id !== activity.id)
  .sort((a, b) => a.data.title.localeCompare(b.data.title));
const start = related.findIndex((a) => a.data.title.localeCompare(d.title) > 0);
const picks = [0, 1, 2]
  .map((i) => related[(Math.max(start, 0) + i) % related.length])
  .filter((a, i, arr) => a && arr.indexOf(a) === i);
---

<Base title={d.title} description={d.blurb}>
  <article class="wrap detail" style={`--cat:${cat.color};--cat-grad:${cat.grad}`}>
    <nav class="crumbs meta-caps">
      <a href={withBase('/')}>← All ideas</a>
      <span aria-hidden="true">/</span>
      <a href={withBase(`/#${d.category}`)} class="crumb-cat">{cat.label}</a>
    </nav>

    <header class="detail-head">
      <div class="head-badges">
        <span class="heat-badge" style={`--c:${heatInfo.color}`}>{heatInfo.label}</span>
        {d.bookAhead && <span class="flag flag-book">Book ahead</span>}
      </div>
      <h1>{d.title}</h1>
      {d.date && <p class="detail-date meta-caps">{d.date}</p>}
      <p class="detail-lede">{d.blurb}</p>
    </header>

    <div class="detail-cols">
      <div class="prose">
        {d.warning && (
          <aside class="warning">
            <span class="meta-caps" style="color:var(--terra);">Heads up</span>
            <p>{d.warning}</p>
          </aside>
        )}
        <Content />
      </div>

      <aside class="facts">
        <dl>
          <div><dt>Where</dt><dd>{d.area}</dd></div>
          <div><dt>Cost</dt><dd>{d.cost}</dd></div>
          {d.driveTime && <div><dt>Drive</dt><dd>{d.driveTime}</dd></div>}
          {d.date && <div><dt>When</dt><dd>{d.date}</dd></div>}
          {d.ages && <div><dt>Ages</dt><dd>{d.ages}</dd></div>}
          <div><dt>Heat plan</dt><dd>{heatInfo.label}</dd></div>
        </dl>
        <div class="fact-actions">
          {d.mapUrl && <a class="btn btn-solid" href={d.mapUrl} target="_blank" rel="noopener">Open map ↗</a>}
          {d.website && <a class="btn btn-ghost" href={d.website} target="_blank" rel="noopener">Website ↗</a>}
        </div>
      </aside>
    </div>

    {picks.length > 0 && (
      <section class="related">
        <h2>More “{cat.label}”</h2>
        <div class="card-grid">
          {picks.map((a, i) => <ActivityCard activity={a} index={i} />)}
        </div>
      </section>
    )}
  </article>
</Base>

<style>
  .detail { padding-top: 2.4rem; }

  .crumbs {
    display: flex;
    gap: 0.7rem;
    margin-bottom: 2.2rem;
  }

  .crumbs a { text-decoration: none; }
  .crumbs a:hover { color: var(--terra); }
  .crumb-cat { color: var(--cat); }

  .detail-head {
    border-bottom: 3px solid transparent;
    border-image: var(--cat-grad) 1;
    padding-bottom: 1.4rem;
    margin-bottom: 2rem;
  }

  .head-badges {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.9rem;
  }

  h1 {
    font-size: clamp(2.2rem, 6vw, 4rem);
    font-weight: 660;
    max-width: 18em;
  }

  .detail-date {
    color: var(--plum);
    font-size: 0.85rem;
    margin: 0.9rem 0 0;
  }

  .detail-lede {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.1rem, 2.4vw, 1.4rem);
    color: var(--ink-soft);
    max-width: 32em;
    margin: 0.8rem 0 0;
  }

  .detail-cols {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: start;
  }

  @media (min-width: 820px) {
    .detail-cols {
      grid-template-columns: minmax(0, 1fr) 300px;
      gap: clamp(1.5rem, 4vw, 3.5rem);
    }
  }

  .warning {
    border: 2px solid var(--terra);
    border-radius: 10px;
    background: color-mix(in srgb, var(--terra) 6%, var(--card));
    padding: 0.9rem 1.1rem;
    margin-bottom: 1.4rem;
  }

  .warning p { margin: 0.3em 0 0; }

  .facts {
    position: static;
    border: 2px solid transparent;
    border-radius: 14px;
    background:
      linear-gradient(var(--card), var(--card)) padding-box,
      var(--cat-grad) border-box;
    padding: 1.2rem 1.3rem 1.4rem;
  }

  @media (min-width: 820px) {
    .facts { position: sticky; top: 84px; }
  }

  .facts dl { margin: 0 0 1.1rem; }

  .facts dl > div {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.55rem 0;
    border-bottom: 1px solid var(--line-soft);
  }

  .facts dt {
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }

  .facts dd {
    margin: 0;
    text-align: right;
    font-weight: 700;
    font-size: 0.92rem;
  }

  .fact-actions {
    display: grid;
    gap: 0.55rem;
  }

  .related { margin-top: 4rem; }

  .related h2 {
    font-size: 1.7rem;
    font-weight: 660;
    margin-bottom: 1.1rem;
  }
</style>
